# === Auth ===
AUTH_JWT_SECRET=change-me-in-production

# === Local PostgreSQL ===
POSTGRES_DB=guimintlab
POSTGRES_USER=guimintlab
POSTGRES_PASSWORD=guimintlab
POSTGRES_PORT=55432
# Optional override for the local API container.
LOCAL_DATABASE_URL=postgresql+asyncpg://guimintlab:guimintlab@db:5432/guimintlab
# Used when running the API natively on the host.
DATABASE_URL=postgresql+asyncpg://guimintlab:guimintlab@localhost:55432/guimintlab

# === Production PostgreSQL ===
# docker-compose.prod.yml also uses DATABASE_URL. Override it in production
# with an external PostgreSQL connection string.

# === API ===
API_HOST=0.0.0.0
API_PORT=8000
# Docker Compose publishes API on http://localhost:58008.
# Native Vite uses http://localhost:5173; full Docker web uses http://localhost:58009.
API_CORS_ORIGINS=http://localhost:5173,http://localhost:58009,http://localhost:3000

# === Web ===
VITE_API_URL=http://localhost:58008
