# === Supabase ===
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=eyJhbGci...
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-dashboard

# === Database (Supabase Postgres) ===
# Use transaction pooler (port 6543) for runtime and migrations
DATABASE_URL=postgresql+asyncpg://postgres.PROJECT:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# === API ===
API_HOST=0.0.0.0
API_PORT=8000
# Docker Compose publishes API on http://localhost:58008.
# Native Vite uses http://localhost:5173; full Docker web uses http://localhost:58009.
API_CORS_ORIGINS=http://localhost:5173,http://localhost:58009,http://localhost:3000

# === Web ===
VITE_API_URL=http://localhost:58008
