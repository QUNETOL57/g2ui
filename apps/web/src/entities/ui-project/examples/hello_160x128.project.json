{
  "schemaVersion": "0.1.0",
  "id": "hello_160",
  "name": "Hello 160x128",
  "display": {
    "width": 160,
    "height": 128,
    "colorFormat": "rgb565"
  },
  "palette": [
    {
      "token": "bg",
      "hex": "#0B1020"
    },
    {
      "token": "fg",
      "hex": "#E6E6E6"
    },
    {
      "token": "accent",
      "hex": "#1E90FF"
    },
    {
      "token": "muted",
      "hex": "#5A6478"
    }
  ],
  "initialScreenId": "screen_main",
