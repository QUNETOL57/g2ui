          "children": [
            {
              "id": "footer_hint",
              "type": "label",
              "frame": {
                "x": 4,
                "y": 112,
                "width": 152,
                "height": 7
              },
              "style": {
                "textColor": {
                  "kind": "token",
                  "token": "fg"
                }
              },
              "props": {
                "text": "IR -> C -> ESP32",
                "align": "center"
              }
            }
          ]
        }
      ]
    }
