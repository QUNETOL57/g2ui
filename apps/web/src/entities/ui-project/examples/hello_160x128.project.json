      "layout": {
        "mode": "absolute",
        "padding": 0
      },
      "style": {
        "background": {
          "kind": "token",
          "token": "bg"
        },
        "drawBackground": true
      },
      "props": {
        "background": {
          "kind": "token",
          "token": "bg"
        }
      },
      "children": [
        {
          "id": "header",
          "type": "panel",
          "name": "Header",
          "frame": {
            "x": 0,
            "y": 0,
            "width": 160,
            "height": 20
          },
          "layout": {
            "mode": "row",
            "padding": 4,
            "gap": 4,
            "align": "center"
          },
          "style": {
            "background": {
              "kind": "token",
              "token": "accent"
            },
            "drawBackground": true
          },
          "children": [
            {
              "id": "header_title",
              "type": "label",
              "frame": {
                "x": 4,
                "y": 4,
                "width": 152,
                "height": 7
              },
              "style": {
                "textColor": {
                  "kind": "token",
                  "token": "fg"
                }
              },
              "props": {
                "text": "G2UI",
                "align": "left"
              }
            }
          ]
        },
        {
          "id": "body",
          "type": "panel",
          "name": "Body",
          "frame": {
            "x": 0,
            "y": 22,
            "width": 160,
            "height": 84
          },
          "layout": {
            "mode": "column",
            "padding": 8,
            "gap": 6
          },
          "style": {
            "background": {
              "kind": "token",
              "token": "bg"
            },
            "drawBackground": true
          },
          "children": [
            {
              "id": "greeting",
              "type": "label",
              "frame": {
                "x": 8,
                "y": 30,
                "width": 144,
                "height": 7
              },
              "style": {
                "textColor": {
                  "kind": "token",
                  "token": "fg"
                }
              },
              "props": {
                "text": "Hello, world!",
                "align": "center"
              }
            },
            {
              "id": "subtitle",
              "type": "label",
              "frame": {
                "x": 8,
                "y": 54,
                "width": 144,
                "height": 7
              },
              "style": {
                "textColor": {
                  "kind": "token",
                  "token": "muted"
                }
              },
              "props": {
                "text": "Built by G2UI",
                "align": "center"
              }
            },
            {
              "id": "start_btn",
              "type": "button",
              "frame": {
                "x": 40,
                "y": 74,
                "width": 80,
                "height": 22
              },
              "style": {
                "background": {
                  "kind": "token",
                  "token": "accent"
                },
                "textColor": {
                  "kind": "token",
                  "token": "fg"
                },
                "borderColor": {
                  "kind": "token",
                  "token": "fg"
                },
                "borderWidth": 1
              },
              "props": {
                "text": "Start",
                "paddingX": 6,
                "paddingY": 3
              },
              "onPress": {
                "kind": "navigate",
                "target": "screen_main"
              }
            }
          ]
        },
        {
          "id": "footer",
          "type": "panel",
          "name": "Footer",
          "frame": {
            "x": 0,
            "y": 108,
            "width": 160,
            "height": 20
          },
          "layout": {
            "mode": "row",
            "padding": 4,
