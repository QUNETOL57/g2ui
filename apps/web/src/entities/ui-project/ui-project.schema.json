{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://g2ui.dev/schema/ui-project.schema.json",
  "title": "G2UI UI Project",
  "type": "object",
  "required": ["schemaVersion", "id", "name", "display", "screens", "initialScreenId"],
  "properties": {
    "schemaVersion": { "const": "0.1.0" },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{0,63}$" },
    "name": { "type": "string" },
    "display": {
      "type": "object",
      "required": ["width", "height", "colorFormat"],
      "properties": {
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "colorFormat": { "const": "rgb565" }
      }
    },
    "palette": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["token", "hex"],
        "properties": {
          "token": { "type": "string" },
          "hex": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" }
        }
      }
    },
    "screens": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/widget" }
    },
    "initialScreenId": { "type": "string" }
  },
  "definitions": {
    "color": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "value"],
          "properties": {
            "kind": { "const": "hex" },
            "value": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" }
          }
        },
        {
          "type": "object",
          "required": ["kind", "token"],
          "properties": {
            "kind": { "const": "token" },
            "token": { "type": "string" }
          }
        }
      ]
    },
    "widget": {
      "type": "object",
      "required": ["id", "type"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{0,63}$" },
        "type": {
          "enum": ["screen", "panel", "label", "button", "icon", "image", "line", "rect"]
        },
        "name": { "type": "string" },
        "visible": { "type": "boolean" },
        "enabled": { "type": "boolean" },
        "frame": {
          "type": "object",
          "required": ["x", "y", "width", "height"],
          "properties": {
            "x": { "type": "integer" },
            "y": { "type": "integer" },
            "width": { "type": "integer", "minimum": 0 },
            "height": { "type": "integer", "minimum": 0 }
          }
        },
        "layout": {
          "type": "object",
          "properties": {
            "mode": { "enum": ["absolute", "row", "column"] },
            "padding": { "type": "integer", "minimum": 0 },
            "gap": { "type": "integer", "minimum": 0 },
            "align": { "enum": ["start", "center", "end", "stretch", "space-between"] },
            "justify": { "enum": ["start", "center", "end", "stretch", "space-between"] }
          }
        },
        "style": {
          "type": "object",
          "properties": {
            "background": { "$ref": "#/definitions/color" },
            "borderColor": { "$ref": "#/definitions/color" },
            "borderWidth": { "type": "integer", "minimum": 0 },
            "borderRadius": { "type": "integer", "minimum": 0 },
            "textColor": { "$ref": "#/definitions/color" },
            "drawBackground": { "type": "boolean" },
            "drawBorder": { "type": "boolean" }
          }
        },
        "props": { "type": "object" },
        "bindings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["signal", "property"],
            "properties": {
              "signal": { "type": "string" },
              "property": { "enum": ["text", "value", "visible", "color"] }
            }
          }
        },
        "onPress": {
          "type": "object",
          "required": ["kind"],
          "properties": {
            "kind": { "enum": ["navigate", "show", "hide", "setText", "setValue"] },
            "target": { "type": "string" },
            "value": { "type": "string" }
          }
        },
        "children": {
          "type": "array",
          "items": { "$ref": "#/definitions/widget" }
        },
        "width": { "type": "integer" },
        "height": { "type": "integer" }
      }
    }
  }
}
